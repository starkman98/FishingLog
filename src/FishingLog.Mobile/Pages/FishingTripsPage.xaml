<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FishingLog.Mobile.Pages.FishingTripsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:entities="clr-namespace:FishingLog.Mobile.Data.Entities"
    xmlns:vm="clr-namespace:FishingLog.Mobile.ViewModels"
    x:DataType="vm:FishingTripsViewModel"
    x:Name="page"
    Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding AddTripCommand}" Order="Primary" Priority="0" />
    </ContentPage.ToolbarItems>

    <!--  Pull-to-refresh triggers a full sync  -->
    <RefreshView Command="{Binding SyncCommand}" IsRefreshing="{Binding IsRefreshing, Mode=OneWay}">
        <CollectionView ItemsSource="{Binding Trips}" SelectionMode="None">

            <CollectionView.EmptyView>
                <Label
                    Margin="24"
                    HorizontalTextAlignment="Center"
                    Text="No fishing trips yet.&#10;Pull down to sync or tap + to add one."
                    VerticalOptions="Center" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entities:FishingTripLocalEntity">
                    <SwipeView>

                        <!--  Swipe left to reveal delete  -->
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem
                                    BackgroundColor="Red"
                                    Command="{Binding Source={x:Reference page}, Path=BindingContext.DeleteTripCommand}"
                                    CommandParameter="{Binding .}"
                                    Text="Delete" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!--  Tap anywhere on the row to edit  -->
                        <Grid
                            Padding="16,12"
                            ColumnDefinitions="*,Auto"
                            RowDefinitions="Auto,Auto,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference page}, Path=BindingContext.SelectTripCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Label
                                Grid.Row="0" Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="16"
                                Text="{Binding Name}" />

                            <Label
                                Grid.Row="1" Grid.Column="0"
                                FontSize="13"
                                Text="{Binding LocationName}"
                                TextColor="Gray" />

                            <Label
                                Grid.Row="2" Grid.Column="0"
                                FontSize="12"
                                Text="{Binding StartTime, StringFormat='{0:MMM dd, yyyy  HH:mm}'}"
                                TextColor="Gray" />

                            <!--  Orange dot = has unsynced local changes  -->
                            <Label
                                Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="3"
                                FontSize="10"
                                IsVisible="{Binding IsDirty}"
                                Text="●"
                                TextColor="Orange"
                                VerticalOptions="Center" />
                        </Grid>

                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </RefreshView>

</ContentPage>