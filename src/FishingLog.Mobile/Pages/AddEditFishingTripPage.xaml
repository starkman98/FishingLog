<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FishingLog.Mobile.Pages.AddEditFishingTripPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FishingLog.Mobile.ViewModels"
    x:DataType="vm:AddEditFishingTripViewModel"
    Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="6">

            <!--  Name  -->
            <Label FontAttributes="Bold" Text="Name *" />
            <Entry Placeholder="e.g. Morning session at the lake" Text="{Binding Name}" />

            <!--  Location  -->
            <Label FontAttributes="Bold" Margin="0,10,0,0" Text="Location" />
            <Entry Placeholder="e.g. Lake Vänern" Text="{Binding LocationName}" />

            <!--  Start date + time  -->
            <Label FontAttributes="Bold" Margin="0,10,0,0" Text="Start Date" />
            <DatePicker Date="{Binding StartDate}" />

            <Label FontAttributes="Bold" Margin="0,6,0,0" Text="Start Time" />
            <TimePicker Time="{Binding StartTimeOfDay}" />

            <!--  End date (optional)  -->
            <HorizontalStackLayout Margin="0,10,0,0" Spacing="8">
                <CheckBox IsChecked="{Binding HasEndDate}" VerticalOptions="Center" />
                <Label Text="Trip has ended" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <DatePicker Date="{Binding EndDate}" IsEnabled="{Binding HasEndDate}" IsVisible="{Binding IsEndDateVisible}" />

            <!--  Notes  -->
            <Label FontAttributes="Bold" Margin="0,10,0,0" Text="Notes" />
            <Editor
                AutoSize="Disabled"
                HeightRequest="120"
                Placeholder="How did it go? Any catches?"
                Text="{Binding Note}" />

            <!--  Save / Cancel  -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
                <Button
                    Grid.Column="0"
                    BackgroundColor="Gray"
                    Command="{Binding CancelCommand}"
                    Text="Cancel"
                    TextColor="White" />
                <Button
                    Grid.Column="1"
                    Command="{Binding SaveCommand}"
                    Text="Save" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>